# Hugging Face token for pyannote speaker-diarization. First accept the gated terms at
# https://huggingface.co/pyannote/speaker-diarization-community-1 (the model whisperx uses).
V2M_HF_TOKEN=
# STT model size: tiny | base | small | medium | large-v3 | large-v3-turbo
# (large-v3-turbo = large-v3 quality, faster decoder — good with V2M_DIARIZE=false)
V2M_WHISPER_MODEL=large-v3-turbo
V2M_HOST=127.0.0.1
V2M_PORT=8000
V2M_LANGUAGE=ko
# Transcribe-quality knobs. suppress_numerals writes spoken numbers as words
# (fewer number misrecognitions); initial_prompt primes the decoder with domain
# terms / names / spelling (empty = none).
V2M_SUPPRESS_NUMERALS=true
V2M_INITIAL_PROMPT=
# Voice-activity detection: silero (fast, default) or pyannote (slower). Affects
# only speech-region segmentation speed, not transcription text quality.
V2M_VAD_METHOD=silero
# Speaker diarization + word alignment (~90% of CPU time on long audio). Set false
# for "fast mode": single-speaker, segment-timestamp transcript that finishes ~10x
# faster — good for long lectures where speaker labels aren't needed.
V2M_DIARIZE=false
# Optional: dir containing ffmpeg.exe if it is not on your system PATH.
# (winget Gyan.FFmpeg example) e.g.
# V2M_FFMPEG_DIR=C:\Users\you\AppData\Local\Microsoft\WinGet\Packages\Gyan.FFmpeg_Microsoft.Winget.Source_8wekyb3d8bbwe\ffmpeg-8.1.1-full_build\bin
V2M_FFMPEG_DIR=
